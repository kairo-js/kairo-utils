{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",

    "moduleResolution": "bundler",

    "rootDir": "src",
    "outDir": "lib",

    "declaration": true,
    "emitDeclarationOnly": true,

    "strict": true,
    "skipLibCheck": true,
    "stripInternal": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
